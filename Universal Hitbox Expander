local Players = game:GetService("Players")

print('Made by HeatRelax, have fun ;)')

while true do
    local LocalPlayer = Players.LocalPlayer
    local TARGET_SIZE = Vector3.new(4, 6, 4)
    
    for _, player in ipairs(Players:GetChildren()) do
        if player:IsA("Player") and LocalPlayer and player ~= LocalPlayer then
            local character = player.Character
            
            if character then
                local head = character:FindFirstChild("Head")
                local headHB = character:FindFirstChild("HeadHB")
                
                local function adjustPart(part)
                    if part and part.Size ~= TARGET_SIZE then
                        part.Size = TARGET_SIZE
                    end
                end
                
                adjustPart(head)
                adjustPart(headHB)
            end
        end
    end
    
    wait(0.5)
end
