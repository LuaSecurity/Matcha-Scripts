_G.EspLibrary = {}
local ESP = _G.EspLibrary

ESP.Config = {
    PlayerESP = true,
    NPCESP = true,
    CustomESP = {}
}
ESP.DrawingObjects = {}
ESP.LoopDelay = 0.1

local function WorldToScreen(pos)
    local cam = workspace:FindFirstChild("CurrentCamera")
    if cam and cam.WorldToViewportPoint then
        local screenPos, _ = cam:WorldToViewportPoint(pos)
        return Vector2.new(screenPos.X, screenPos.Y)
    else
        return Vector2.new(pos.X, pos.Z)
    end
end

function ESP:Clear()
    for _, draw in pairs(self.DrawingObjects) do
        if draw then draw:Remove() end
    end
    self.DrawingObjects = {}
end

function ESP:GetOrCreateDrawing(key, color, radius)
    if not self.DrawingObjects[key] then
        local draw = Drawing.new("Circle")
        draw.Color = color or Color3.new(1,1,1)
        draw.Visible = true
        draw.Radius = radius or 8
        self.DrawingObjects[key] = draw
    end
    return self.DrawingObjects[key]
end

function ESP:DrawPlayers()
    for _, player in ipairs(game.Players:GetChildren()) do
        if player == game.Players.LocalPlayer then continue end
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
        local pos = WorldToScreen(char.HumanoidRootPart.Position)
        local draw = self:GetOrCreateDrawing(player.Name, Color3.new(0,1,0), 8)
        draw.Position = pos
    end
end

function ESP:DrawNPCs()
    for _, npc in ipairs(workspace:GetChildren()) do
        if npc:IsA("Model") and npc:FindFirstChild("Humanoid") and npc:FindFirstChild("HumanoidRootPart") then
            local pos = WorldToScreen(npc.HumanoidRootPart.Position)
            local draw = self:GetOrCreateDrawing(npc:GetFullName(), Color3.new(1,1,0), 8)
            draw.Position = pos
        end
    end
end

function ESP:DrawCustom()
    for key, color in pairs(self.Config.CustomESP) do
        for _, inst in ipairs(workspace:GetDescendants()) do
            if inst.Name == key or inst.ClassName == key then
                local pos
                if inst:IsA("BasePart") then
                    pos = WorldToScreen(inst.Position)
                elseif inst:IsA("Model") and inst.PrimaryPart then
                    pos = WorldToScreen(inst.PrimaryPart.Position)
                end
                if pos then
                    local draw = self:GetOrCreateDrawing(inst:GetFullName(), color, 8)
                    draw.Position = pos
                end
            end
        end
    end
end

spawn(function()
    local lastLoopTime = os.clock()
    while true do
        if os.clock() - lastLoopTime >= ESP.LoopDelay then
            lastLoopTime = os.clock()
            if ESP.Config.PlayerESP then ESP:DrawPlayers() end
            if ESP.Config.NPCESP then ESP:DrawNPCs() end
            ESP:DrawCustom()
        end
        task.wait()
    end
end)
