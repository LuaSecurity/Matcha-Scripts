-- Create global table if not exists
_G.EspLibrary = _G.EspLibrary or {}
local EspLibrary = _G.EspLibrary

EspLibrary.Config = EspLibrary.Config or {
    PlayerESP = true,
    NPCESP = true,
    CustomESP = {},
    Box = true,
    Name = true
}

EspLibrary.Tracked = EspLibrary.Tracked or {}
local Tracked = EspLibrary.Tracked

local Workspace = workspace

local function WorldToScreen(pos)
    local cam = Workspace.CurrentCamera
    if cam and cam.WorldToViewportPoint then
        local screenPos, onScreen = cam:WorldToViewportPoint(pos)
        return Vector2.new(screenPos.X, screenPos.Y), onScreen
    else
        return Vector2.new(pos.X, pos.Z), true
    end
end

local function ScanWorkspace()
    local valid = {}
    for _, inst in ipairs(Workspace:GetDescendants()) do
        for name, cfg in pairs(EspLibrary.Config.CustomESP) do
            if inst.Name == name or inst.ClassName == name then
                if inst:IsA("BasePart") or (inst:IsA("Model") and inst.PrimaryPart) then
                    local root = inst:IsA("BasePart") and inst or inst.PrimaryPart
                    local addr = tostring(root)
                    valid[addr] = true
                    if not Tracked[addr] then
                        local text = Drawing.new("Text")
                        text.Text = cfg.Text or name
                        text.Center = true
                        text.Outline = true
                        text.Color = cfg.Color or Color3.new(1,1,1)
                        text.Visible = false

                        local box = Drawing.new("Square")
                        box.Thickness = 1
                        box.Filled = false
                        box.Color = cfg.Color or Color3.new(1,1,1)
                        box.Visible = false

                        Tracked[addr] = {Root = root, Box = box, Text = text, Config = cfg}
                    end
                end
            end
        end
    end

    for addr, info in pairs(Tracked) do
        if not valid[addr] then
            if info.Box then info.Box:Remove() end
            if info.Text then info.Text:Remove() end
            Tracked[addr] = nil
        end
    end
end

local function UpdateESP()
    for _, info in pairs(Tracked) do
        local root, box, text, cfg = info.Root, info.Box, info.Text, info.Config
        if root and root.Position then
            local headPos, onScreen1 = WorldToScreen(root.Position + Vector3.new(0,2,0))
            local legPos, onScreen2 = WorldToScreen(root.Position - Vector3.new(0,2,0))
            if onScreen1 and onScreen2 then
                local h = math.abs(headPos.Y - legPos.Y)
                local w = h / 1.5
                local x, y = headPos.X - w/2, headPos.Y
                if box then
                    box.Position = Vector2.new(x,y)
                    box.Size = Vector2.new(w,h)
                    box.Visible = cfg.Box ~= false and EspLibrary.Config.Box
                    box.Color = cfg.Color or box.Color
                end
                if text then
                    text.Position = Vector2.new(headPos.X, y - 16)
                    text.Visible = cfg.Name ~= false and EspLibrary.Config.Name
                    text.Color = cfg.Color or text.Color
                    text.Text = cfg.Text or text.Text
                end
            else
                if box then box.Visible = false end
                if text then text.Visible = false end
            end
        else
            if box then box.Visible = false end
            if text then text.Visible = false end
        end
    end
end

spawn(function()
    while true do
        ScanWorkspace()
        UpdateESP()
        task.wait(0.1)
    end
end)
