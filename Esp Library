local Library = {}
Library.__index = Library

function Library:New()
    local self = setmetatable({}, Library)
    self.Config = {
        Color = Color3.fromRGB(255, 80, 80),
        Box = true,
        Name = true,
        RefreshRate = 0.3
    }
    self._espObjects = {}
    self._running = false
    return self
end

local camera = workspace.CurrentCamera
local run = game:GetService("RunService")

local function toScreen(pos)
    local s, vis = camera:WorldToViewportPoint(pos)
    return Vector2.new(s.X, s.Y), vis
end

function Library:_clear()
    for _, esp in pairs(self._espObjects) do
        if esp.Text then esp.Text:Remove() end
        if esp.Box then esp.Box:Remove() end
    end
    table.clear(self._espObjects)
end

function Library:_makeESP(part, label)
    local box = Drawing.new("Square")
    box.Thickness = 1
    box.Filled = false
    box.Color = self.Config.Color
    box.Visible = false

    local text = Drawing.new("Text")
    text.Center = true
    text.Outline = true
    text.Color = self.Config.Color
    text.Size = 16
    text.Text = label
    text.Visible = false

    self._espObjects[part] = {Box = box, Text = text, Part = part}
end

function Library:_update()
    for part, esp in pairs(self._espObjects) do
        if part and part.Parent then
            local pos, vis = toScreen(part.Position)
            if vis then
                local dist = (camera.CFrame.Position - part.Position).Magnitude
                local size = math.clamp(2000 / dist, 10, 100)
                esp.Box.Size = Vector2.new(size, size)
                esp.Box.Position = pos - esp.Box.Size / 2
                esp.Box.Color = self.Config.Color
                esp.Box.Visible = self.Config.Box

                esp.Text.Position = Vector2.new(pos.X, pos.Y - size / 1.5)
                esp.Text.Color = self.Config.Color
                esp.Text.Visible = self.Config.Name
            else
                esp.Box.Visible = false
                esp.Text.Visible = false
            end
        else
            if esp.Box then esp.Box:Remove() end
            if esp.Text then esp.Text:Remove() end
            self._espObjects[part] = nil
        end
    end
end

function Library:CreateESP(targetName)
    self:_clear()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == targetName then
            self:_makeESP(obj, obj.Name)
        end
    end
end

function Library:Start()
    if self._running then return end
    self._running = true
    run.RenderStepped:Connect(function()
        self:_update()
    end)
    task.spawn(function()
        while self._running do
            for _, esp in pairs(self._espObjects) do
                if not esp.Part or not esp.Part.Parent then
                    if esp.Box then esp.Box:Remove() end
                    if esp.Text then esp.Text:Remove() end
                    self._espObjects[esp] = nil
                end
            end
            task.wait(self.Config.RefreshRate)
        end
    end)
end

function Library:Stop()
    self._running = false
    self:_clear()
end

return Library:New()
