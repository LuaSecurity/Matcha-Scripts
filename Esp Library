local ESP = {}
ESP.Config = {
    Color = Color3.fromRGB(255, 255, 255)
}

local drawings = {}

function ESP:CreateESP(obj)
    if not obj or drawings[obj] then return end

    local box = Drawing.new("Square")
    box.Color = self.Config.Color
    box.Thickness = 1
    box.Filled = false
    box.Visible = true

    drawings[obj] = box
end

function ESP:Update()
    for obj, box in pairs(drawings) do
        if obj and obj:IsDescendantOf(workspace) then
            local pos, visible = WorldToScreen(obj.Position)
            if visible then
                box.Position = Vector2.new(pos.X - 10, pos.Y - 10)
                box.Size = Vector2.new(20, 20)
                box.Visible = true
                box.Color = self.Config.Color
            else
                box.Visible = false
            end
        else
            box:Remove()
            drawings[obj] = nil
        end
    end
end

function ESP:Start()
    task.spawn(function()
        while true do
            task.wait(0.01)
            self:Update()
        end
    end)
end

return ESP
